{#
  Characters index page.

  Narrators listed first. Then characters grouped by role,
  roles sorted by total narrative load descending.

  Context:
    narrators: list of narrator char dicts
    role_groups: list of (role_name, char_list) tuples
#}
# Characters

---
{% for char in narrators %}
- {{ char.name | wikilink }}
  **Narrator**{{ " · " ~ char.role if char.role else "" }}
{% if char.metrics %}
  {{ char.metrics }}
{% endif %}
{% if char.based_on %}
  ← {{ char.based_on }}
{% endif %}
{% endfor %}
{% for role, chars in role_groups %}

## {{ role }}
{% for char in chars %}
- {{ char.name | wikilink }}
{% if char.metrics %}
  {{ char.metrics }}
{% endif %}
{% if char.based_on %}
  ← {{ char.based_on }}
{% endif %}
{% endfor %}
{% endfor %}
