{#
  Characters index page.

  Narrators listed first, then all characters sorted by
  scene count descending. Role shown inline, capitalized.

  Context:
    narrators: list of narrator char dicts
    characters: list of non-narrator char dicts sorted by involvement
    character_count: int
#}
# Characters

{{ character_count | zpad }} characters

---
{% for char in narrators %}
- {{ char.name | wikilink }} · **Narrator**{{ " · " ~ char.role if char.role else "" }}
{% endfor %}
{% for char in characters %}
- {{ char.name | wikilink }}{{ " · " ~ char.role if char.role else "" }}
  {{ char.scene_count }} scene{{ "s" if char.scene_count != 1 else "" }}{% if char.chapter_count %} · {{ char.chapter_count }} chapter{{ "s" if char.chapter_count != 1 else "" }}{% endif %}

{% endfor %}
