{#
  Event index page.

  Events grouped by year and month based on earliest entry date.
  Undated events listed separately at the end.

  Context:
    event_count: int
    year_groups: list of dicts:
      - year: int
      - months: list of dicts:
          - month: str (full month name)
          - events: list of dicts:
              - name: str
              - scene_count: int
              - entry_count: int
    undated: list of dicts:
      - name: str
      - scene_count: int
      - entry_count: int
#}
# Events

{{ event_count | zpad }} events

---
{% for yg in year_groups %}

## {{ yg.year }}
{% for mg in yg.months %}

### {{ mg.month }}
{% for event in mg.events %}
- {{ event.entry_count | zpad }}e · {{ event.scene_count | zpad }}s · {{ event.name | wikilink }}
{% endfor %}
{% endfor %}
{% endfor %}
{% if undated %}

## Undated
{% for event in undated %}
- {{ event.entry_count | zpad }}e · {{ event.scene_count | zpad }}s · {{ event.name | wikilink }}
{% endfor %}
{% endif %}
