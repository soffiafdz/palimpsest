{#
  Tags index page.

  Alphabetically sorted tags with usage counts, grouped by first letter.

  Context:
    tags: list of dicts (sorted alphabetically by name):
      - name: str
      - count: int
#}
# Tags

{{ tags | length | zpad }} tags

---
{% if tags %}
{% set ns = namespace(letter='') %}
{% for tag in tags %}
{% set first = tag.name[0] | upper %}
{% if first != ns.letter %}
{% set ns.letter = first %}

## {{ first }}
{% endif %}
- {{ tag.name | wikilink }} · {{ tag.count | zpad }}
{% endfor %}
{% endif %}
